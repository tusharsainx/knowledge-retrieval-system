# Google Gemini API Config (For embeddings and LLM)
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=

# LlamaParse API Config (For PDF parsing)
# Get a key from LlamaCloud: https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY=

# Cohere Rerank API Config (For serverless reranking)
# Get a key from Cohere Dashboard: https://dashboard.cohere.com/
COHERE_API_KEY=

# Qdrant Cloud Configurations (For hybrid vector database)
# Get coordinates from Qdrant Cloud: https://cloud.qdrant.io/
QDRANT_URL=
QDRANT_API_KEY=

# PostgreSQL Configurations (For metadata store, e.g. Neon, Supabase, or Local Docker)
# Default points to local Postgres container for ease of testing
DATABASE_URL=postgresql+asyncpg://admin:admin@localhost:5432/doc_processor

# S3 / MinIO Configurations (For PDF storage)
# Default points to local MinIO container for local verification
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=documents

# Redis Configurations (For arq async task broker, e.g. Upstash or Local Docker)
# Default points to local Redis container for ease of testing
REDIS_URL=redis://localhost:6379/0
